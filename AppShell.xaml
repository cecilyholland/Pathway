<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Pathway.Views"
       x:Class="Pathway.AppShell"
       FlyoutBehavior="Flyout"
       Title="Pathway">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="200" BackgroundColor="{StaticResource PrimaryColor}">
            <VerticalStackLayout VerticalOptions="Center" Padding="20">
                <Label Text="Pathway" 
                       FontSize="24" 
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="Your work. Mapped." 
                       FontSize="14" 
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <ShellContent Title="Map"
                  ContentTemplate="{DataTemplate views:MapPage}"/>

    <Shell.FlyoutFooter>
        <StackLayout Padding="20">
            <Label x:Name="SyncStatusLabel" 
                   Text="All changes synced" 
                   HorizontalOptions="Center"
                   FontSize="12"/>
            <Label x:Name="ConnectionStatusLabel" 
                   Text="Online" 
                   HorizontalOptions="Center"
                   FontSize="12"/>
        </StackLayout>
    </Shell.FlyoutFooter>

</Shell>