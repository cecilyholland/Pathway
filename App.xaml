<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pathway.App"
             xmlns:converters="clr-namespace:Pathway.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- App-wide colors -->
            <Color x:Key="PrimaryColor">#498B4E</Color>
            <Color x:Key="SecondaryColor">#E8F5E9</Color>
            <Color x:Key="TertiaryColor">#2E7D32</Color>
            <Color x:Key="AccentColor">#2196F3</Color>
            <Color x:Key="NeutralColor">#9E9E9E</Color>

            <!-- Button styles -->
            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="5" />
                <Setter Property="Padding" Value="15,10" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>