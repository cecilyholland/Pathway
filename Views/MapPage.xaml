<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Pathway.ViewModels"
             x:Class="Pathway.Views.MapPage"
             Title="Campus Map">

    <ContentPage.BindingContext>
        <viewmodels:MapViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Top Controls -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Padding="10">
            <SearchBar Grid.Column="0" 
                       Placeholder="Search areas or plants..." 
                       Text="{Binding SearchQuery}"
                       SearchCommand="{Binding SearchCommand}" />

            <Button Grid.Column="1" 
                    Text="Filter" 
                    Command="{Binding FilterCommand}"
                    Margin="5,0,0,0" />

            <Button Grid.Column="2" 
                    Text="Sync" 
                    Command="{Binding SyncCommand}"
                    Margin="5,0,0,0" 
                    IsVisible="{Binding IsConnected}" />
        </Grid>

        <!-- Map and Overlay Panel -->
        <Grid Grid.Row="1">
            <!-- Map Placeholder - will be replaced with actual map in code -->
            <Rectangle Fill="#E0E0E0" />

            <Label Text="Map Component Will Appear Here" 
                  HorizontalOptions="Center"
                  VerticalOptions="Center"
                  TextColor="Gray"
                  FontSize="18" />

            <!-- Bottom Panel for Selected Area/Plant Details -->
            <Frame IsVisible="{Binding IsDetailsPanelVisible}"
                   VerticalOptions="End"
                   BackgroundColor="White"
                   BorderColor="LightGray"
                   CornerRadius="10"
                   Margin="10"
                   Padding="15"
                   HeightRequest="200">

                <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,Auto">
                    <!-- Header with Title and Close Button -->
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="{Binding SelectedItemName}"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Button Grid.Row="0" Grid.Column="1"
                            Text="✕"
                            FontSize="16"
                            WidthRequest="30"
                            HeightRequest="30"
                            Padding="0"
                            Command="{Binding CloseDetailsPanelCommand}" />

                    <!-- Details Content -->
                    <ScrollView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                        <StackLayout>
                            <Label Text="{Binding SelectedItemDescription}" />
                            <Label Text="{Binding SelectedItemStatus, StringFormat='Status: {0}'}" />
                        </StackLayout>
                    </ScrollView>

                    <!-- Action Buttons -->
                    <StackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalOptions="End"
                                Spacing="10">

                        <Button Text="View Details"
                                Command="{Binding ViewDetailsCommand}" />

                        <Button Text="Tasks"
                                Command="{Binding ViewTasksCommand}" />
                    </StackLayout>
                </Grid>
            </Frame>

            <!-- Connection Status Indicator -->
            <Frame IsVisible="{Binding IsOffline}"
                   BackgroundColor="#CC3333"
                   VerticalOptions="Start"
                   HorizontalOptions="Center"
                   Padding="10,5"
                   Margin="0,10,0,0"
                   CornerRadius="20">
                <Label Text="Offline Mode - Changes will sync when connected"
                       TextColor="White"
                       FontSize="12" />
            </Frame>

            <!-- Sync Status Indicator -->
            <Frame IsVisible="{Binding IsSyncing}"
                   BackgroundColor="#3366CC"
                   VerticalOptions="Start"
                   HorizontalOptions="Center"
                   Padding="10,5"
                   Margin="0,10,0,0"
                   CornerRadius="20">
                <Label Text="Syncing data..."
                       TextColor="White"
                       FontSize="12" />
            </Frame>
        </Grid>
    </Grid>
</ContentPage>